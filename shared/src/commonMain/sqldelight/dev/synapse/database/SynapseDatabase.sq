CREATE TABLE IF NOT EXISTS Collections (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL UNIQUE,
    color TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS Notes (
    id TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    content_raw TEXT NOT NULL,
    collection_id TEXT NOT NULL DEFAULT 'raw',
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    view_count INTEGER NOT NULL DEFAULT 0,
    FOREIGN KEY (collection_id) REFERENCES Collections(id)
);

CREATE TABLE IF NOT EXISTS NoteEmbeddings (
    note_id TEXT NOT NULL PRIMARY KEY,
    embedding BLOB NOT NULL,
    FOREIGN KEY (note_id) REFERENCES Notes(id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS Attributes (
    id TEXT NOT NULL PRIMARY KEY,
    note_id TEXT NOT NULL,
    attr_key TEXT NOT NULL,
    attr_value TEXT NOT NULL,
    FOREIGN KEY (note_id) REFERENCES Notes(id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS Edges (
    id TEXT NOT NULL PRIMARY KEY,
    source_id TEXT NOT NULL,
    target_id TEXT NOT NULL,
    label TEXT NOT NULL,
    FOREIGN KEY (source_id) REFERENCES Notes(id) ON DELETE CASCADE,
    FOREIGN KEY (target_id) REFERENCES Notes(id) ON DELETE CASCADE
);

getNoteMetadataById:
SELECT id, title, content_raw, updated_at, collection_id FROM Notes WHERE id = ?;

getAllNoteMetadata:
SELECT id, title, content_raw, updated_at, collection_id FROM Notes ORDER BY updated_at DESC;

getForwardLinksMetadata:
SELECT n.id, n.title, n.content_raw, n.updated_at, n.collection_id FROM Notes n
JOIN Edges e ON n.id = e.target_id
WHERE e.source_id = ?;

getBackLinksMetadata:
SELECT n.id, n.title, n.content_raw, n.updated_at, n.collection_id FROM Notes n
JOIN Edges e ON n.id = e.source_id
WHERE e.target_id = ?;

insertNote:
INSERT OR REPLACE INTO Notes(id, title, content_raw, collection_id, created_at, updated_at, view_count)
VALUES (?, ?, ?, ?, ?, ?, ?);

updateNoteContent:
UPDATE Notes SET content_raw = ?, updated_at = ? WHERE id = ?;

deleteNote:
DELETE FROM Notes WHERE id = ?;

getNoteById:
SELECT * FROM Notes WHERE id = ?;

getNoteByRowId:
SELECT * FROM Notes WHERE rowid = ?;

getAllNotes:
SELECT * FROM Notes ORDER BY updated_at DESC;

getNoteByTitle:
SELECT * FROM Notes WHERE title = ? LIMIT 1;

insertEmbedding:
INSERT OR REPLACE INTO NoteEmbeddings(note_id, embedding)
VALUES (?, ?);

getEmbedding:
SELECT embedding FROM NoteEmbeddings WHERE note_id = ?;

getAllNoteEmbeddings:
SELECT ne.note_id, ne.embedding, n.rowid AS note_rowid
FROM NoteEmbeddings ne
JOIN Notes n ON ne.note_id = n.id;

deleteEmbedding:
DELETE FROM NoteEmbeddings WHERE note_id = ?;

getTagsForNote:
SELECT attr_value FROM Attributes WHERE note_id = ? AND attr_key = 'tag';

insertAttribute:
INSERT OR REPLACE INTO Attributes(id, note_id, attr_key, attr_value)
VALUES (?, ?, ?, ?);

getAttributesForNote:
SELECT * FROM Attributes WHERE note_id = ?;

deleteAttributesForNote:
DELETE FROM Attributes WHERE note_id = ?;

insertEdge:
INSERT OR REPLACE INTO Edges(id, source_id, target_id, label)
VALUES (?, ?, ?, ?);

getEdgesForNote:
SELECT * FROM Edges WHERE source_id = ? OR target_id = ?;

getForwardLinks:
SELECT n.* FROM Notes n
JOIN Edges e ON n.id = e.target_id
WHERE e.source_id = ?;

getBackLinks:
SELECT n.* FROM Notes n
JOIN Edges e ON n.id = e.source_id
WHERE e.target_id = ?;

deleteOutgoingEdges:
DELETE FROM Edges WHERE source_id = ?;

deleteEdgesForNote:
DELETE FROM Edges WHERE source_id = ? OR target_id = ?;

-- Collection Queries
getAllCollections:
SELECT * FROM Collections;

insertCollection:
INSERT OR REPLACE INTO Collections(id, name, color)
VALUES (?, ?, ?);

deleteCollection:
DELETE FROM Collections WHERE id = ?;

updateCollectionName:
UPDATE Collections SET name = ? WHERE id = ?;

updateCollectionColor:
UPDATE Collections SET color = ? WHERE id = ?;

countNotesInCollection:
SELECT COUNT(*) FROM Notes WHERE collection_id = ?;

seedInitialCollections:
INSERT OR IGNORE INTO Collections (id, name, color) VALUES 
('raw', 'Raw', '#BDBDBD'),
('lit', 'Lit', '#64B5F6'),
('evergreen', 'Evergreen', '#4CAF50');

-- FTS5 Search
CREATE VIRTUAL TABLE IF NOT EXISTS NotesFTS USING fts5(
    id UNINDEXED,
    title,
    content_raw,
    content='Notes',
    content_rowid='rowid'
);

-- Triggers to keep FTS in sync using rowid for external content
CREATE TRIGGER IF NOT EXISTS notes_ai AFTER INSERT ON Notes BEGIN
  INSERT INTO NotesFTS(rowid, id, title, content_raw) VALUES (new.rowid, new.id, new.title, new.content_raw);
END;

CREATE TRIGGER IF NOT EXISTS notes_ad AFTER DELETE ON Notes BEGIN
  INSERT INTO NotesFTS(NotesFTS, rowid, id, title, content_raw) VALUES('delete', old.rowid, old.id, old.title, old.content_raw);
END;

CREATE TRIGGER IF NOT EXISTS notes_au AFTER UPDATE ON Notes BEGIN
  INSERT INTO NotesFTS(NotesFTS, rowid, id, title, content_raw) VALUES('delete', old.rowid, old.id, old.title, old.content_raw);
  INSERT INTO NotesFTS(rowid, id, title, content_raw) VALUES (new.rowid, new.id, new.title, new.content_raw);
END;

searchNotesKeyword:
SELECT n.*
FROM Notes n
JOIN NotesFTS ON n.rowid = NotesFTS.rowid
WHERE NotesFTS MATCH :query
ORDER BY bm25(NotesFTS);


-- Note: NotesVec table and index are created manually in DatabaseDriverFactory
-- to avoid SQLDelight parser issues with libSQL-specific syntax.

