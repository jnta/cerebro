CREATE TABLE Collections (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL UNIQUE,
    color TEXT NOT NULL
);

-- Seed initial collections matching previous NoteCategory enum
INSERT INTO Collections (id, name, color) VALUES ('raw', 'Raw', '#BDBDBD');
INSERT INTO Collections (id, name, color) VALUES ('lit', 'Lit', '#64B5F6');
INSERT INTO Collections (id, name, color) VALUES ('evergreen', 'Evergreen', '#4CAF50');

-- Add collection_id to Notes and migrate data
ALTER TABLE Notes ADD COLUMN collection_id TEXT NOT NULL DEFAULT 'raw' REFERENCES Collections(id);

UPDATE Notes SET collection_id = LOWER(category);
